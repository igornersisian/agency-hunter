# === Required for Telegram bot ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# === Gmail OAuth ===
# On server: base64-encoded contents of credentials.json and token.json
# Run locally: cat credentials.json | base64 -w0
# Run locally: cat token.json | base64 -w0
GMAIL_CREDENTIALS_B64=
GMAIL_TOKEN_B64=
# These are set automatically by entrypoint.sh on the server:
GMAIL_OAUTH_CREDENTIALS_PATH=/app/credentials.json
GMAIL_TOKEN_PATH=/app/token.json

# === Email sending ===
AGENCY_SENDER_EMAIL=you@example.com
AGENCY_SENDER_PHYSICAL_ADDRESS=Your City, Country
AGENCY_DAILY_SEND_CAP=10
AGENCY_FIT_THRESHOLD=70

# === LLM (for enrichment, classification, drafting) ===
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# === Discovery (optional — only for /fetch pipeline) ===
# Apify supports token rotation: set APIFY_API_TOKEN plus any number of
# APIFY_API_TOKEN2, APIFY_API_TOKEN3, ... — the runner auto-switches to the
# next one when the current account hits its credit/quota limit.
APIFY_API_TOKEN=
APIFY_API_TOKEN2=
APIFY_API_TOKEN3=
SCRAPERAPI_KEY=
SCRAPERAPI_KEY_2=

# === CRW (self-hosted Rust scraper, Firecrawl-compatible) ===
# Preferred enrichment backend: better Cloudflare bypass, faster than
# ScraperAPI, free (self-hosted on Dokploy). When set, enrich auto-uses it.
CRW_API_URL=https://crw.deploybox.space
CRW_API_KEY=
